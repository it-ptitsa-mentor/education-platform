{
  "name": "education-platform",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:feature": "vitest run --config vitest.feature.config.ts",
    "generate:static-exercises": "tsx scripts/generate-static-exercises.mts",
    "generate:static-quizzes": "tsx scripts/generate-static-quizzes.mts",
    "generate:course-content": "tsx scripts/generate-course-content.mts",
    "watch:course-theory": "tsx scripts/watch-course-theory.mts",
    "export:roadmap-content": "tsx scripts/export-roadmap-content.mts",
    "generate:roadmap-content": "tsx scripts/generate-roadmap-content.mts",
    "import:hexlet-frontend": "tsx scripts/import-hexlet-frontend.mts",
    "import:hexlet-files": "tsx scripts/import-hexlet-exercise-files.mts",
    "import:hexlet-quizzes": "tsx scripts/import-hexlet-quizzes.mts",
    "generate:js-tests": "tsx scripts/generate-exercise-tests.mts",
    "generate:exercise-tests": "tsx scripts/generate-exercise-tests.mts",
    "validate:exercise-tests": "tsx scripts/validate-exercise-tests.mts",
    "dev": "pnpm --parallel -r dev",
    "dev:api": "pnpm --filter @ptitsa/api dev",
    "dev:web": "pnpm --filter @ptitsa/web dev",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.12.0",
