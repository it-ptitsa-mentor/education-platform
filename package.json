{
  "name": "education-platform",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:feature": "vitest run --config vitest.feature.config.ts",
    "dev": "pnpm --parallel -r dev",
    "dev:api": "pnpm --filter @ptitsa/api dev",
    "dev:web": "pnpm --filter @ptitsa/web dev",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
