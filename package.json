    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.21",
    "axios": "^1.18.1",
    "classnames": "^2.5.1",
    "es-toolkit": "^1.49.0",
    "escape-goat": "^4.0.0",
    "i18next": "^26.3.4",
    "imask": "^7.6.1",
    "immutability-helper": "^3.1.1",
    "jquery": "^4.0.0",
    "jsdom": "^29.1.1",
    "lodash": "^4.18.1",
    "msw": "^2.14.6",
    "nock": "^14.0.16",
    "react": "^19.1.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.3.0",
    "react-test-renderer": "^19.2.7",
